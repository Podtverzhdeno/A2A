# Core
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./data/a2a.db

# Supplier agents: use "embedded" for unit tests/legacy demo or "remote" for A2A.
SUPPLIER_MODE=remote
SUPPLIER_ENDPOINTS=supplier-a=http://127.0.0.1:8201,supplier-b=http://127.0.0.1:8202,supplier-c=http://127.0.0.1:8203
SUPPLIER_TIMEOUT_SECONDS=5
SUPPLIER_MAX_ATTEMPTS=2
MINIMUM_QUOTES=2
DEMO_IDENTITY_ENABLED=false
DEMO_IDENTITY_HEADER=X-Demo-User

# LLM provider: disabled | openrouter | gigachat
LLM_PROVIDER=disabled

# OpenRouter (required only when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=

# GigaChat (required only when LLM_PROVIDER=gigachat)
# Use either GIGACHAT_CREDENTIALS or GIGACHAT_ACCESS_TOKEN.
GIGACHAT_CREDENTIALS=
GIGACHAT_ACCESS_TOKEN=
GIGACHAT_MODEL=
GIGACHAT_SCOPE=
GIGACHAT_BASE_URL=
GIGACHAT_CA_BUNDLE_FILE=
GIGACHAT_VERIFY_SSL_CERTS=true
